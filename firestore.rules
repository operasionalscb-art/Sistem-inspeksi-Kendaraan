rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidVehicle(data) {
      return data.keys().hasAll(['plateNumber', 'model', 'brand', 'lastOdometer', 'userId']) 
        && data.keys().size() == 5
        && data.plateNumber is string && data.plateNumber.size() <= 20
        && data.model is string && data.model.size() <= 100
        && data.brand is string && data.brand.size() <= 100
        && data.lastOdometer is number && data.lastOdometer >= 0
        && data.userId is string;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['userId', 'vehicleId', 'type', 'date', 'items', 'odometer', 'signature', 'summary'])
        && data.keys().size() == 8
        && data.userId is string
        && data.vehicleId is string
        && data.type in ['harian', 'mingguan', 'bulanan']
        && data.date is string
        && data.items is list && data.items.size() <= 100
        && data.odometer is number && data.odometer >= 0
        && data.signature is string && data.signature.size() <= 100000 // Base64 limit
        && data.summary is string && data.summary.size() <= 5000;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'date', 'read'])
        && data.keys().size() == 6
        && data.userId is string
        && data.title is string && data.title.size() <= 200
        && data.message is string && data.message.size() <= 1000
        && data.type in ['info', 'warning', 'success']
        && data.date is string
        && data.read is bool;
    }

    // --- Collection Routes ---

    match /vehicles/{vehicleId} {
      allow get: if isSignedIn() && isValidId(vehicleId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidVehicle(request.resource.data);
      allow update: if isSignedIn() && isValidId(vehicleId) && (
        (isValidVehicle(request.resource.data) && request.resource.data.userId == resource.data.userId) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastOdometer']) && request.resource.data.lastOdometer is number)
      );
      allow delete: if isSignedIn() && isValidId(vehicleId);
    }

    match /reports/{reportId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidReport(request.resource.data);
      allow update, delete: if false; // Reports are immutable after creation
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow update: if isSignedIn() 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        && request.resource.data.read == true; // Only allow marking as read
      allow create, delete: if false; // System generated
    }

    match /drivers/{driverId} {
      allow read, write: if isSignedIn();
    }
  }
}
