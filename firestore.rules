rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isRegistered() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider != "anonymous";
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    // --- Entity Validations ---

    function isValidVehicle(data) {
      return data.keys().hasAll(['plateNumber', 'model', 'brand', 'lastOdometer', 'userId']) 
        && data.keys().size() == 5
        && data.plateNumber is string && data.plateNumber.size() <= 20
        && data.model is string && data.model.size() <= 100
        && data.brand is string && data.brand.size() <= 100
        && data.lastOdometer is number && data.lastOdometer >= 0
        && data.userId is string;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['userId', 'vehicleId', 'type', 'date', 'items', 'odometer', 'signature', 'summary'])
        && data.keys().size() == 8
        && data.userId is string
        && data.vehicleId is string
        && data.type in ['harian', 'mingguan', 'bulanan']
        && data.date is string
        && data.items is list && data.items.size() <= 100
        && data.odometer is number && data.odometer >= 0
        && data.signature is string && data.signature.size() <= 100000 // Base64 limit
        && data.summary is string && data.summary.size() <= 5000;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'date', 'read'])
        && data.keys().size() == 6
        && data.userId is string
        && data.title is string && data.title.size() <= 200
        && data.message is string && data.message.size() <= 1000
        && data.type in ['info', 'warning', 'success']
        && data.date is string
        && data.read is bool;
    }

    function isValidRepair(data) {
      return data.keys().hasAll(['id', 'vehicleId', 'itemLabel', 'dateCreated', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.vehicleId is string && data.vehicleId.size() <= 128
        && data.itemLabel is string && data.itemLabel.size() <= 500
        && data.dateCreated is string && data.dateCreated.size() <= 64
        && data.status in ['pending', 'in_progress', 'resolved'];
    }

    // --- Collection Routes ---

    match /vehicles/{vehicleId} {
      allow get: if isValidId(vehicleId);
      allow list: if true;
      allow create: if isRegistered() && isValidVehicle(request.resource.data);
      allow update: if isRegistered() && isValidId(vehicleId) && (
        isValidVehicle(request.resource.data) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastOdometer']) && request.resource.data.lastOdometer is number)
      );
      allow delete: if isRegistered() && isValidId(vehicleId);
    }

    match /reports/{reportId} {
      allow get: if true;
      allow list: if true;
      allow create: if isRegistered() && isValidReport(request.resource.data);
      allow update, delete: if false; // Reports are immutable after creation
    }

    match /notifications/{notificationId} {
      allow get: if true;
      allow list: if true;
      allow update: if isRegistered() 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        && request.resource.data.read == true; // Only allow marking as read
      allow create, delete: if false; // System generated
    }

    match /repairs/{repairId} {
      allow get: if isValidId(repairId);
      allow list: if true;
      allow create: if isRegistered() && isValidRepair(request.resource.data);
      allow update: if isRegistered() && isValidId(repairId) && isValidRepair(request.resource.data);
      allow delete: if isRegistered() && isValidId(repairId);
    }

    match /drivers/{driverId} {
      allow read: if true;
      allow write: if isRegistered();
    }
  }
}
